# ── Shared Supabase project (create via Supabase dashboard or MCP; see docs/memory.md TODO 3)
# App (Expo) reads EXPO_PUBLIC_*; web (Next.js) reads NEXT_PUBLIC_*.
# Only the anon (publishable) key may appear in these client-visible vars — never the service role key.

# apps/mobile/.env
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# apps/web/.env.local
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# ── Observability (apps/web; also set on Vercel). All optional — absent keys = no-op.
# PostHog project API key (docs/analytics-plan.md; cookieless, anonymous)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Sentry (errors only; tracesSampleRate=0)
NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest.sentry.io/...
# Sentry source-map upload — CI/Vercel only, never needed locally
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Canonical origin for metadata/sitemap (set to the real domain on Vercel)
NEXT_PUBLIC_SITE_URL=https://YOUR-DOMAIN

# Server-only (apps/web/.env.local; never NEXT_PUBLIC_, never in the app)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
ANTHROPIC_API_KEY=sk-ant-...
